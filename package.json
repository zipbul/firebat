{
  "name": "firebat",
  "module": "firebat.ts",
  "bin": {
    "firebat": "./dist/firebat.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/firebat.js"
    },
    "./oxlint-plugin": {
      "import": "./dist/oxlint-plugin.js"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "firebat": "bun dist/firebat.js --log-level trace",
    "firebat:install": "bun dist/firebat.js install",
    "firebat:update": "bun dist/firebat.js update",
    "firebat:agent": "bun dist/firebat.js --log-level error",
    "firebat:ci": "bun dist/firebat.js --log-level debug",
    "db:generate": "bunx -y drizzle-kit generate --config ./drizzle.config.ts",
    "db:migrate": "bunx -y drizzle-kit migrate --config ./drizzle.config.ts",
    "coverage": "bun test --coverage",
    "lint": "oxlint src firebat.ts oxlint-plugin.ts --config .oxlintrc.jsonc --type-aware --tsconfig tsconfig.json",
    "format": "oxfmt . --config .oxfmtrc.jsonc --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@zipbul/gildash": "0.40.0",
    "drizzle-orm": "^0.45.1",
    "fastbitset": "^0.4.1",
    "oxc-parser": "0.127.0",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "oxlint-tsgolint": "^0.11.5",
    "typescript": "5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/bun": "^1.3.9",
    "@types/fastbitset": "^0.2.2",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  }
}
