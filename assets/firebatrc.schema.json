{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firebat.dev/schemas/firebatrc.schema.json",
  "title": "Firebat Config (.firebatrc.jsonc)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "features": {
      "type": "object",
      "description": "Per-feature enable/disable + feature-specific options. false disables. true enables with defaults. An object enables with explicit options (empty objects are allowed).",
      "additionalProperties": false,
      "properties": {
        "duplicates": {
          "$ref": "#/$defs/duplicatesToggle"
        },
        "barrel-policy": {
          "$ref": "#/$defs/barrelPolicyToggle"
        },
        "unknown-proof": {
          "$ref": "#/$defs/unknownProofToggle"
        },
        "format": { "$ref": "#/$defs/emptyToggle" },
        "indirection": {
          "$ref": "#/$defs/indirectionToggle"
        },
        "waste": { "$ref": "#/$defs/wasteToggle" },
        "lint": { "$ref": "#/$defs/emptyToggle" },
        "typecheck": { "$ref": "#/$defs/emptyToggle" },
        "dependencies": { "$ref": "#/$defs/dependenciesToggle" },
        "coupling": { "$ref": "#/$defs/couplingToggle" },
        "nesting": { "$ref": "#/$defs/nestingToggle" },
        "early-return": { "$ref": "#/$defs/emptyToggle" },
        "error-flow": { "$ref": "#/$defs/emptyToggle" },

        "temporal-coupling": { "$ref": "#/$defs/emptyToggle" },
        "variable-lifetime": { "$ref": "#/$defs/variableLifetimeToggle" },
        "giant-file": { "$ref": "#/$defs/giantFileToggle" }
      }
    },
    "mcp": {
      "description": "MCP tool overrides. Use 'inherit' to reuse root config. Per-feature values can be false | true | 'inherit' | {options} (empty objects are allowed).",
      "oneOf": [
        { "type": "string", "const": "inherit" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "features": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "duplicates": { "$ref": "#/$defs/duplicatesInheritable" },
                "barrel-policy": { "$ref": "#/$defs/barrelPolicyInheritable" },
                "unknown-proof": { "$ref": "#/$defs/unknownProofInheritable" },
                "format": { "$ref": "#/$defs/emptyInheritable" },
                "indirection": { "$ref": "#/$defs/indirectionInheritable" },
                "waste": { "$ref": "#/$defs/wasteInheritable" },
                "lint": { "$ref": "#/$defs/emptyInheritable" },
                "typecheck": { "$ref": "#/$defs/emptyInheritable" },
                "dependencies": { "$ref": "#/$defs/dependenciesInheritable" },
                "coupling": { "$ref": "#/$defs/couplingInheritable" },
                "nesting": { "$ref": "#/$defs/nestingInheritable" },
                "early-return": { "$ref": "#/$defs/emptyInheritable" },
                "error-flow": { "$ref": "#/$defs/emptyInheritable" },

                "temporal-coupling": { "$ref": "#/$defs/emptyInheritable" },
                "variable-lifetime": { "$ref": "#/$defs/variableLifetimeInheritable" },
                "giant-file": { "$ref": "#/$defs/giantFileInheritable" }
              }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "minSize": {
      "oneOf": [
        { "type": "string", "const": "auto" },
        { "type": "integer", "minimum": 0 }
      ]
    },
    "emptyToggle": {
      "description": "false disables; true enables.",
      "type": "boolean"
    },
    "emptyInheritable": {
      "description": "false disables; true enables; 'inherit' uses root.",
      "oneOf": [{ "type": "boolean" }, { "type": "string", "const": "inherit" }]
    },
    "dependenciesOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "glob": { "type": "string", "minLength": 1 }
            },
            "required": ["name", "glob"]
          }
        },
        "allowedDependencies": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      },
      "required": ["layers", "allowedDependencies"],
      "minProperties": 2
    },
    "dependenciesToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        { "$ref": "#/$defs/dependenciesOptions" }
      ]
    },
    "dependenciesInheritable": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "string", "const": "inherit" },
        { "type": "boolean", "const": true },
        { "$ref": "#/$defs/dependenciesOptions" }
      ]
    },
    "wasteToggle": {
      "type": "boolean"
    },
    "wasteInheritable": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "string", "const": "inherit" }
      ]
    },
    "duplicatesToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": { "minSize": { "$ref": "#/$defs/minSize", "default": "auto" } },
          "required": ["minSize"],
          "minProperties": 1
        }
      ]
    },
    "unknownProofToggle": {
      "description": "false disables; true enables.",
      "type": "boolean"
    },
    "barrelPolicyToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ignoreGlobs": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Additional ignore globs for barrel-policy. Default ignores are minimal: node_modules/** and dist/**."
            }
          }
        }
      ]
    },
    "indirectionToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": { "maxForwardDepth": { "type": "integer", "minimum": 0, "default": 0 } },
          "required": ["maxForwardDepth"],
          "minProperties": 1
        }
      ]
    },
    "duplicatesInheritable": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "string", "const": "inherit" },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": { "minSize": { "$ref": "#/$defs/minSize", "default": "auto" } },
          "required": ["minSize"],
          "minProperties": 1
        }
      ]
    },
    "unknownProofInheritable": {
      "description": "false disables; true enables; 'inherit' uses root.",
      "oneOf": [{ "type": "boolean" }, { "type": "string", "const": "inherit" }]
    },
    "barrelPolicyInheritable": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "string", "const": "inherit" },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ignoreGlobs": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Additional ignore globs for barrel-policy. Default ignores are minimal: node_modules/** and dist/**."
            }
          }
        }
      ]
    },
    "indirectionInheritable": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "string", "const": "inherit" },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": { "maxForwardDepth": { "type": "integer", "minimum": 0, "default": 0 } },
          "required": ["maxForwardDepth"],
          "minProperties": 1
        }
      ]
    },

    "nestingOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxCognitiveComplexity": {
          "type": "integer",
          "minimum": 0,
          "description": "Cognitive complexity threshold (default: 15)"
        },
        "maxCallbackDepth": { "type": "integer", "minimum": 0, "description": "Callback nesting depth threshold (default: 3)" },
        "maxPromiseChainDepth": {
          "type": "integer",
          "minimum": 0,
          "description": "Promise chain depth threshold (default: 3)"
        },
        "maxNestingDepth": {
          "type": "integer",
          "minimum": 0,
          "description": "Control-flow nesting depth threshold (default: 3)"
        },
        "minDensityLoc": { "type": "integer", "minimum": 0, "description": "Minimum LOC for density check (default: 8)" },
        "maxDensity": { "type": "number", "minimum": 0, "maximum": 1, "description": "Max CC/LOC density (default: 0.5)" }
      }
    },
    "nestingToggle": {
      "oneOf": [{ "type": "boolean", "const": false }, { "type": "boolean", "const": true }, { "$ref": "#/$defs/nestingOptions" }]
    },
    "nestingInheritable": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "string", "const": "inherit" },
        { "type": "boolean", "const": true },
        { "$ref": "#/$defs/nestingOptions" }
      ]
    },

    "couplingOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "godModulePercent": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Fraction of total modules for god-module fanIn/fanOut threshold (default: 0.1)"
        },
        "godModuleMin": { "type": "integer", "minimum": 0, "description": "Minimum absolute god-module threshold (default: 10)" },
        "rigidPercent": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Fraction of total modules for rigid fanIn threshold (default: 0.15)"
        },
        "rigidMin": { "type": "integer", "minimum": 0, "description": "Minimum absolute rigid threshold (default: 10)" },
        "distanceThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Off-main-sequence distance threshold (default: 0.7)"
        },
        "unstableInstability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Instability threshold for unstable-module (default: 0.8)"
        },
        "unstableFanOut": { "type": "integer", "minimum": 0, "description": "FanOut threshold for unstable-module (default: 5)" },
        "rigidInstability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Instability upper bound for rigid-module (default: 0.2)"
        }
      }
    },
    "couplingToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        { "$ref": "#/$defs/couplingOptions" }
      ]
    },
    "couplingInheritable": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "string", "const": "inherit" },
        { "type": "boolean", "const": true },
        { "$ref": "#/$defs/couplingOptions" }
      ]
    },

    "variableLifetimeToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": { "maxLifetimeLines": { "type": "integer", "minimum": 0 } }
        }
      ]
    },
    "variableLifetimeInheritable": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "string", "const": "inherit" },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": { "maxLifetimeLines": { "type": "integer", "minimum": 0 } }
        }
      ]
    },

    "giantFileToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": { "maxLines": { "type": "integer", "minimum": 0 } }
        }
      ]
    },
    "giantFileInheritable": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "string", "const": "inherit" },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": { "maxLines": { "type": "integer", "minimum": 0 } }
        }
      ]
    }
  }
}
