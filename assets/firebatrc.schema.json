{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firebat.dev/schemas/firebatrc.schema.json",
  "title": "Firebat Config (.firebatrc.jsonc)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "features": {
      "type": "object",
      "description": "Per-feature enable/disable + feature-specific options. false disables. true enables with defaults. An object enables with explicit options (empty objects are allowed).",
      "additionalProperties": false,
      "properties": {
        "duplicates": {
          "$ref": "#/$defs/duplicatesToggle"
        },
        "barrel": {
          "$ref": "#/$defs/barrelToggle"
        },
        "unknown-proof": {
          "$ref": "#/$defs/unknownProofToggle"
        },
        "format": { "$ref": "#/$defs/emptyToggle" },
        "indirection": {
          "$ref": "#/$defs/indirectionToggle"
        },
        "waste": { "$ref": "#/$defs/wasteToggle" },
        "lint": { "$ref": "#/$defs/emptyToggle" },
        "typecheck": { "$ref": "#/$defs/emptyToggle" },
        "dependencies": { "$ref": "#/$defs/dependenciesToggle" },
        "nesting": { "$ref": "#/$defs/nestingToggle" },
        "early-return": { "$ref": "#/$defs/emptyToggle" },
        "error-flow": { "$ref": "#/$defs/emptyToggle" },

        "temporal-coupling": { "$ref": "#/$defs/emptyToggle" },
        "variable-lifetime": { "$ref": "#/$defs/variableLifetimeToggle" },
        "giant-file": { "$ref": "#/$defs/giantFileToggle" }
      }
    }
  },
  "$defs": {
    "minSize": {
      "oneOf": [
        { "type": "string", "const": "auto" },
        { "type": "integer", "minimum": 0 }
      ]
    },
    "emptyToggle": {
      "description": "false disables; true enables.",
      "type": "boolean"
    },
    "dependenciesOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "glob": { "type": "string", "minLength": 1 }
            },
            "required": ["name", "glob"]
          }
        },
        "allowedDependencies": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        },
        "entry": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Additional entry-point globs (root-relative). Files matching become reachability roots for unused-file detection."
        },
        "ignore": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Globs (root-relative) of files excluded from unused-file reporting."
        },
        "ignoreDependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Package-name globs excluded from unused-dependency reporting (declared out-of-graph consumption, e.g. presets loaded by string)."
        }
      },
      "required": ["layers", "allowedDependencies"],
      "minProperties": 2
    },
    "dependenciesToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        { "$ref": "#/$defs/dependenciesOptions" }
      ]
    },
    "wasteToggle": {
      "type": "boolean"
    },
    "duplicatesToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": { "minSize": { "$ref": "#/$defs/minSize", "default": "auto" } },
          "required": ["minSize"],
          "minProperties": 1
        }
      ]
    },
    "unknownProofToggle": {
      "description": "false disables; true enables.",
      "type": "boolean"
    },
    "barrelToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ignoreGlobs": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Additional ignore globs for barrel. Default ignores are minimal: node_modules/** and dist/**."
            }
          }
        }
      ]
    },
    "indirectionToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": { "maxForwardDepth": { "type": "integer", "minimum": 0, "default": 0 } },
          "required": ["maxForwardDepth"],
          "minProperties": 1
        }
      ]
    },
    "nestingOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxCognitiveComplexity": {
          "type": "integer",
          "minimum": 0,
          "description": "Cognitive complexity threshold (default: 15)"
        },
        "maxCallbackDepth": { "type": "integer", "minimum": 0, "description": "Callback nesting depth threshold (default: 3)" },
        "maxPromiseChainDepth": {
          "type": "integer",
          "minimum": 0,
          "description": "Promise chain depth threshold (default: 3)"
        },
        "maxNestingDepth": {
          "type": "integer",
          "minimum": 0,
          "description": "Control-flow nesting depth threshold (default: 3)"
        },
        "minDensityLoc": { "type": "integer", "minimum": 0, "description": "Minimum LOC for density check (default: 8)" },
        "maxDensity": { "type": "number", "minimum": 0, "maximum": 1, "description": "Max CC/LOC density (default: 0.5)" }
      }
    },
    "nestingToggle": {
      "oneOf": [{ "type": "boolean", "const": false }, { "type": "boolean", "const": true }, { "$ref": "#/$defs/nestingOptions" }]
    },
    "variableLifetimeToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxLifetimeLines": { "type": "integer", "minimum": 0 },
            "maxLiveVariables": { "type": "integer", "minimum": 0 },
            "minFunctionLines": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "giantFileToggle": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "type": "boolean", "const": true },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxLines": {
              "type": "integer",
              "minimum": 0,
              "description": "Line-count budget (default: 1000, applied when omitted or when the toggle is `true`/`{}`)."
            }
          }
        }
      ]
    }
  }
}
